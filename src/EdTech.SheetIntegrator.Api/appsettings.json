{
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=EdTechSheetIntegrator;User Id=sa;Password=Your_password123;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "edtech-sheet-integrator",
    "Audience": "edtech-sheet-integrator-clients",
    "SigningKey": "REPLACE_WITH_AT_LEAST_32_BYTES_OF_RANDOM_DATA_IN_PRODUCTION",
    "TokenLifetimeMinutes": 60
  },
  "Upload": {
    "MaxFileSizeBytes": 10485760
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
