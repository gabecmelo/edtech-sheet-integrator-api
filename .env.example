# Copy this file to .env and fill in real values before running docker compose.
# .env is listed in .gitignore — never commit secrets.

# SQL Server SA password (min 8 chars, upper + lower + digit + symbol).
SA_PASSWORD=Your_password123

# JWT signing key — at least 32 characters, generated randomly.
JWT_SIGNING_KEY=change-me-use-a-strong-random-key-here-32+chars
